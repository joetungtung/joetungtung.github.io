# -*- coding: utf-8 -*-
import logging
from pathlib import Path
from dotenv import load_dotenv

def setup_logging():
    Path("logs").mkdir(exist_ok=True)
    logging.basicConfig(
        filename="logs/mail_fetch.log",
        level=logging.INFO,
        format="[%(asctime)s] %(levelname)s %(message)s",
    )
    logging.getLogger().addHandler(logging.StreamHandler())  # 同步印到螢幕

def main():
    load_dotenv()
    setup_logging()
    logging.info("Framework boot OK. (No plugins yet)")
    print("✅ Framework OK — 下一步我們會接上 MailPluginEWS")

if __name__ == "__main__":
    main()