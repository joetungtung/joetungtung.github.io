    try:
        # ★ 先判斷產品別，傳給 parser
        product_key = detect_product_key(path)
        if product_key == "unknown":
            print(f"[WARN] 無法判斷產品別，先跳過：{path.name}")
            continue

        # 這裡改成帶 product_key
        df = parse_csv_generic(path, product_key=product_key)

        if df is None or df.empty:
            print(f"[WARN] 空檔案或無資料：{path.name}")
            continue

        rows = len(df)
        write_to_influx(cli, BUCKET, MEASUREMENT, df)
        total_rows += rows

        record_success(path, rows_written=rows, save_hash=check_hash)
        print(f"[OK] 匯入成功：{path.name} ({product_key}, {rows} 筆)")

    except Exception as e:
        import traceback; traceback.print_exc()
