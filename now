# ===== Exchange 連線 =====
MAIL_EWS_SERVER=https://mail.company.com/EWS/Exchange.asmx
MAIL_USERNAME=DOMAIN\\your_account
MAIL_PASSWORD=your_password
MAIL_PRIMARY_SMTP=your.name@company.com

# ===== 篩選與存檔設定 =====
MAIL_FOLDER_PATH=Inbox/Alerts
MAIL_SUBJECT_INCLUDE=SOC|WAF|Radware|FW
MAIL_ONLY_UNREAD=true
MAIL_SINCE_DAYS=7
MAIL_SAVE_DIR=data/waf            # 先指定一個目標夾；下一步我會教你自動分流
MAIL_MOVE_PROCESSED_TO=Processed
MAIL_MARK_READ_AFTER=true

# ===== 安全與連線行為 =====
MAIL_VERIFY_SSL=true
MAIL_TIMEOUT_SEC=60
MAIL_MAX_ITEMS=300