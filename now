import time
import pytz
from exchangelib.protocol import FaultTolerance, AUTH_TYPE_NTLM, BaseProtocol
from exchangelib.version import Version, EXCHANGE_2016

# 降低同時連線數，避免伺服器覺得你很吵
BaseProtocol.SESSION_POOLSIZE = 1

# 減噪：測試階段若關閉 SSL 驗證，把警告也關掉（正式環境建議開啟驗證）
if not self.s.verify_ssl:
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# 溫和 backoff（伺服器給秒數優先；否則 10→20→40....，最多 5 分鐘）
class GentleRetryPolicy(FaultTolerance):
    max_wait = 300
    base = 10
    factor = 2.0
    _tries = 0
    def back_off(self, seconds=None, **kwargs):
        if seconds is not None:
            wait = float(seconds)
        else:
            wait = self.base * (self.factor ** self._tries)
        self._tries += 1
        wait = min(self.max_wait, wait)
        logger.warning("伺服器要求等待 %.1f 秒以避開節流 (backoff)...", wait)
        time.sleep(wait)

