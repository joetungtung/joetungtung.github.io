creds = Credentials(username=self.s.username, password=self.s.password)

if autodiscover:
    # 路徑一：Autodiscover（有些環境這條比較順）
    logger.info("使用 Autodiscover 連線（5.5.1 compat mode）")
    self.account = Account(
        primary_smtp_address=self.s.primary_smtp,
        credentials=creds,
        autodiscover=True,
        access_type=DELEGATE,
        default_timezone=self.tz,
    )
else:
    # 路徑二：明確指定 server + NTLM + Exchange 版本（避免 version guess）
    logger.info("使用 明確伺服器 連線（5.5.1 compat mode, NTLM + EXCHANGE_2016）")
    config = Configuration(
        server=server,                        # 只給主機名
        credentials=creds,
        auth_type=AUTH_TYPE_NTLM,             # 多數 on-prem EWS 走 NTLM
        version=Version(EXCHANGE_2016),       # 避免 Version.guess() 額外呼叫
        retry_policy=GentleRetryPolicy(),
    )
    self.account = Account(
        primary_smtp_address=self.s.primary_smtp,
        config=config,
        autodiscover=False,
        access_type=DELEGATE,
        default_timezone=self.tz,
    )

logger.info("EWS 連線完成：%s", getattr(self.account.protocol, "service_endpoint", ""))
logger.info("目標儲存路徑：%s", str(self.save_path))