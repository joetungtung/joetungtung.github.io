from exchangelib.errors import RateLimitError
from exchangelib.protocol import BaseProtocol, FaultTolerance
import time

# 調整節流參數
class GentleRetryPolicy(FaultTolerance):
    max_wait = 120  # 最多等待 120 秒
    def back_off(self, **kwargs):
        wait = min(self.max_wait, kwargs.get("seconds", 10))
        logger.warning("伺服器要求等待 %.1f 秒以避開節流...", wait)
        time.sleep(wait)

