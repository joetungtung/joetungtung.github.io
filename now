def _get_folder(self):
    # 空值 → 直接用 Inbox
    if not self.s.folder_path:
        return self.account.inbox

    # 標準化（去空白）
    path = [p for p in self.s.folder_path.split("/") if p]

    # 若以 Inbox 開頭，就從 account.inbox 往下找（最省流量）
    if path and path[0].lower() == "inbox":
        folder = self.account.inbox
        for p in path[1:]:
            folder = folder / p
        return folder

    # 其餘情況才用 root 走（成本較高）
    folder = self.account.root
    for p in path:
        folder = folder / p
    return folder