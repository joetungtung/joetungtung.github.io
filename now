# --- import checkpoint state (SQLite) ---
import sqlite3, hashlib, time
from pathlib import Path

STATE_DB = Path("import_state.sqlite")

def _state_db():
    conn = sqlite3.connect(STATE_DB)
    conn.execute("""
    CREATE TABLE IF NOT EXISTS files (
        path TEXT PRIMARY KEY,
        size INTEGER,
        mtime_ns INTEGER,
        sha1 TEXT,
        rows_written INTEGER,
        last_seen INTEGER
    )
    """)
    return conn

def file_sha1(p: Path, block=1024*1024) -> str:
    h = hashlib.sha1()
    with p.open("rb") as f:
        while True:
            b = f.read(block)
            if not b: break
            h.update(b)
    return h.hexdigest()

def already_imported(p: Path, *, use_hash: bool = False) -> bool:
    """回傳 True = 已成功匯入且檔案未變更"""
    st = p.stat()
    conn = _state_db()
    cur = conn.execute("SELECT size, mtime_ns, sha1 FROM files WHERE path=?", (str(p),))
    row = cur.fetchone()
    conn.close()
    if not row:
        return False
    size, mtime_ns, sha1 = row
    if st.st_size != size or st.st_mtime_ns != mtime_ns:
        return False
    if use_hash:
        # 更嚴謹：比對 sha1
        return sha1 == file_sha1(p)
    return True

def record_success(p: Path, rows_written: int, *, save_hash: bool = False):
    st = p.stat()
    sha1 = file_sha1(p) if save_hash else None
    conn = _state_db()
    conn.execute(
        "INSERT OR REPLACE INTO files(path,size,mtime_ns,sha1,rows_written,last_seen) VALUES (?,?,?,?,?,?)",
        (str(p), st.st_size, st.st_mtime_ns, sha1, rows_written, int(time.time()))
    )
    conn.commit()
    conn.close()




