# --- GentleRetryPolicy v2: 支援伺服器秒數 + 指數回退 ---
import time
from exchangelib.protocol import FaultTolerance

class GentleRetryPolicy(FaultTolerance):
    max_wait = 300  # 最多等 5 分鐘
    base = 10       # 起始等候秒數（若伺服器沒給 seconds）
    factor = 2.0    # 指數回退倍率
    _tries = 0

    def back_off(self, seconds=None, **kwargs):
        if seconds is not None:
            wait = float(seconds)
        else:
            wait = self.base * (self.factor ** self._tries)
        self._tries += 1
        wait = min(self.max_wait, wait)
        logger.warning("伺服器要求等待 %.1f 秒以避開節流 (backoff)...", wait)
        time.sleep(wait)
