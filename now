from pathlib import Path

def detect_product_key(p: Path) -> str:
    """依檔名/路徑自動判斷產品別：radware / waf / fw（全小寫）"""
    name = p.name.lower()
    parts = [seg.lower() for seg in p.parts] + [name]

    # Radware / DefensePro
    if any(("radware" in seg) or ("defensepro" in seg) for seg in parts):
        return "radware"

    # WAF（依你檔名長相，也可加 imperva 等關鍵字）
    if any(("waf" in seg) or ("imperva" in seg) for seg in parts):
        return "waf"

    # FW（防火牆；你檔名看起來有 "FW"）
    if any((" fw" in seg) or seg.startswith("fw") or ("firewall" in seg) for seg in [f" {name}"] + parts):
        return "fw"

    return "unknown"





