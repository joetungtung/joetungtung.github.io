from pathlib import Path

def main(input_dir: str = "downloads", only_new: bool = True, check_hash: bool = False):
    """
    input_dir : 要匯入的 CSV 資料夾
    only_new  : True = 只匯入沒匯過的檔案
    check_hash: True = 比對檔案內容 SHA1（最保險，但略慢）
    """

    root = Path(input_dir)
    if not root.exists():
        print(f"[ERROR] ❌ 找不到資料夾: {root}")
        return

    total_rows = 0
    print(f"📁 掃描資料夾：{root.resolve()}")

    # 依序處理所有 CSV 檔
    for path in sorted(root.glob("*.csv")):

        # ✅ 1. 檢查是否已匯入過（如果沒有變更就跳過）
        if only_new and already_imported(path, use_hash=check_hash):
            print(f"[SKIP] {path.name} (已匯入且未變更)")
            continue

        try:
            # ✅ 2. 讀取並解析 CSV
            df = parse_csv_generic(path)
            if df is None or df.empty:
                print(f"[WARN] 空檔案或無資料：{path.name}")
                continue

            rows = len(df)

            # ✅ 3. 寫入 InfluxDB
            write_to_influx(cli, BUCKET, MEASUREMENT, df)
            total_rows += rows

            # ✅ 4. 匯入成功 → 記錄狀態（下次跳過）
            record_success(path, rows_written=rows, save_hash=check_hash)
            print(f"[OK] ✅ 匯入成功：{path.name} ({rows} 筆)")

        except Exception as e:
            import traceback; traceback.print_exc()
            print(f"[ERROR] 匯入失敗：{path.name} ({e})")
            continue

    print(f"[SUMMARY] ✨ 匯入完成，共 {total_rows} 筆")