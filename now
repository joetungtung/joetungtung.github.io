# -*- coding: utf-8 -*-
import logging
from pathlib import Path
from dotenv import load_dotenv
from mail_fetcher.mail_plugin_ews import MailPluginEWS, settings_from_env

def setup_logging():
    Path("logs").mkdir(exist_ok=True)
    logging.basicConfig(
        filename="logs/mail_fetch.log",
        level=logging.INFO,
        format="[%(asctime)s] %(levelname)s %(message)s",
    )
    logging.getLogger().addHandler(logging.StreamHandler())  # 同步印到螢幕

def main():
    load_dotenv()
    setup_logging()

    settings = settings_from_env()
    plugin = MailPluginEWS(settings)

    saved = plugin.fetch_and_save_csv()
    print(f"✅ Mail fetch complete. CSV saved: {saved}")

if __name__ == "__main__":
    main()